#!/usr/bin/env bash
set -euo pipefail

# ==============================================
# Minecraft Bedrock Backup Script (Termux)
# Dengan Global Progress Bar & Manual Select
# ==============================================

# ===== Konfigurasi =====
SOURCE="$HOME/storage/shared/Android/data/com.mojang.minecraftpe/files/games/com.mojang"
DEST_BASE="$HOME/storage/emulated/0/Documents/mc-backup"
MAX_BACKUP=10
LOGFILE="$DEST_BASE/backup.log"

BEHAVIOR_PATHS=("development_behavior_packs" "behavior_packs")
RESOURCE_PATHS=("development_resource_packs" "resource_packs")
WORLD_PATHS=("minecraftWorlds" "world_templates")

EXCLUDE_LIST=("logs" "cache")

# ===== Util =====
info()    { echo -e "ℹ️  \033[1;34m$1\033[0m"; }
success() { echo -e "✅ \033[1;32m$1\033[0m"; }
warn()    { echo -e "⚠️  \033[1;33m$1\033[0m"; }
error()   { echo -e "❌ \033[1;31m$1\033[0m"; }

toast() {
    command -v termux-toast >/dev/null && termux-toast "$1" || true
}

log() {
    mkdir -p "$DEST_BASE"
    echo "$(date '+%F %T') | $1" >> "$LOGFILE"
}

# ===== Hitung total size =====
calc_total_size() {
    du -sb "$@" 2>/dev/null | awk '{s+=$1} END {print s}'
}

# ===== Copy dengan progress global =====
copy_with_progress() {
    local dest="$1"; shift
    local items=("$@")

    mkdir -p "$dest"

    info "Menghitung total ukuran..."
    TOTAL_SIZE=$(calc_total_size "${items[@]}")

    [[ -z "$TOTAL_SIZE" || "$TOTAL_SIZE" -eq 0 ]] && {
        warn "Tidak ada data untuk disalin."
        return
    }

    info "Menyalin data..."
    tar -cf - "${items[@]}" \
        | pv -s "$TOTAL_SIZE" \
        | tar -xf - -C "$dest"

    success "Copy selesai"
}

# ===== Zip dengan progress =====
zip_with_progress() {
    local folder="$1"
    local out="$2"

    SIZE=$(du -sb "$folder" | awk '{print $1}')

    tar -cf - "$(basename "$folder")" \
        | pv -s "$SIZE" \
        | pigz > "$out"
}

# ===== Manual select =====
manual_select_folders() {
    find "$SOURCE" -maxdepth 1 -mindepth 1 -type d \
        -printf "%f\n" \
        | fzf --multi --prompt "Pilih folder > "
}

# ===== Cleanup backup lama =====
cleanup_old_backups() {
    local dest="$1"

    mapfile -t ALL < <(
        find "$dest" -maxdepth 1 \( -type d -name "backup_*" -o -type f -name "*.zip" \) | sort
    )

    local TOTAL=${#ALL[@]}
    (( TOTAL <= MAX_BACKUP )) && return

    local DEL=$(( TOTAL - MAX_BACKUP ))
    warn "Menghapus $DEL backup lama..."

    for ((i=0; i<DEL; i++)); do
        rm -rf "${ALL[$i]}"
        info "Dihapus: ${ALL[$i]}"
    done
}

# ===== Backup utama =====
backup() {
    local category="$1"
    local zip="$2"

    DATE=$(date +"%Y-%m-%d_%H-%M")
    DEST="$DEST_BASE/$category"
    BACKUP_DIR="$DEST/backup_$DATE"

    mkdir -p "$DEST"
    toast "Backup $category dimulai..."

    ITEMS=()

    case "$category" in
        behavior) ITEMS=("${BEHAVIOR_PATHS[@]/#/$SOURCE/}") ;;
        resource) ITEMS=("${RESOURCE_PATHS[@]/#/$SOURCE/}") ;;
        world)    ITEMS=("${WORLD_PATHS[@]/#/$SOURCE/}") ;;
        all)      ITEMS=("$SOURCE") ;;
        manual)
            mapfile -t SELECTED < <(manual_select_folders)
            [[ "${#SELECTED[@]}" -eq 0 ]] && { warn "Tidak ada pilihan"; exit 0; }
            for f in "${SELECTED[@]}"; do
                ITEMS+=("$SOURCE/$f")
            done
            ;;
        *) error "Kategori tidak dikenal"; exit 1 ;;
    esac

    copy_with_progress "$BACKUP_DIR" "${ITEMS[@]}"

    if [[ "$zip" == "yes" ]]; then
        info "Membuat ZIP..."
        (
            cd "$DEST"
            zip_with_progress "backup_$DATE" "backup_$DATE.zip"
            rm -rf "backup_$DATE"
        )
        SIZE=$(du -sh "$DEST/backup_$DATE.zip" | cut -f1)
        success "ZIP selesai ($SIZE)"
        toast "Backup ZIP selesai ($SIZE)"
        log "Backup $category ZIP ($SIZE)"
    else
        SIZE=$(du -sh "$BACKUP_DIR" | cut -f1)
        success "Backup folder selesai ($SIZE)"
        toast "Backup selesai ($SIZE)"
        log "Backup $category folder ($SIZE)"
    fi

    cleanup_old_backups "$DEST"
}

# ===== Menu =====
menu() {
    OPTIONS=("behavior" "resource" "world" "manual" "all" "keluar")
    CATEGORY=$(printf "%s\n" "${OPTIONS[@]}" | fzf --prompt "Backup > ")

    [[ -z "$CATEGORY" || "$CATEGORY" == "keluar" ]] && exit 0

    read -p "Kompres ke ZIP? (Y/n): " ans
    [[ "$ans" =~ ^[Nn]$ ]] && ZIP="no" || ZIP="yes"

    backup "$CATEGORY" "$ZIP"
}

# ===== CLI =====
if [[ $# -ge 1 ]]; then
    backup "$1" "${2:-no}"
else
    menu
fi